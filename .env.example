# ============================================================
# FloatChat Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Database ---
POSTGRES_USER=floatchat
POSTGRES_PASSWORD=floatchat_secret
POSTGRES_DB=argo_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://floatchat:floatchat_secret@localhost:5432/argo_db

# --- Vector DB (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=argo_profiles

# --- LLM Provider: openai | ollama | together | groq ---
LLM_PROVIDER=ollama
LLM_MODEL=mistral

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Together.ai (if LLM_PROVIDER=together)
TOGETHER_API_KEY=...
TOGETHER_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Groq (if LLM_PROVIDER=groq)
GROQ_API_KEY=...
GROQ_MODEL=llama3-70b-8192

# Ollama (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Embeddings ---
EMBEDDING_PROVIDER=local
# local = sentence-transformers (no API key needed)
# openai = text-embedding-3-small (needs OPENAI_API_KEY)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- App Settings ---
APP_TITLE=FloatChat
APP_LOG_LEVEL=INFO
MAX_SQL_ROWS=5000
RAG_TOP_K=8
MCP_SERVER_PORT=8080
