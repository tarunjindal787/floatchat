# Streamlit Cloud secrets — copy this to the Streamlit Cloud dashboard
# Settings > Secrets section. Do NOT commit this file to Git.

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER = "openai"
OPENAI_API_KEY = "sk-..."          # Replace with your real key
OPENAI_MODEL = "gpt-4o-mini"       # cheaper than gpt-4o for PoC

# ── Supabase PostgreSQL (free at supabase.com) ────────────────────────────────
DATABASE_URL = "postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

# ── ChromaDB — use cloud or disable and use in-memory ─────────────────────────
# Option A: cloud ChromaDB (https://trychroma.com)
CHROMA_HOST = "api.trychroma.com"
CHROMA_PORT = 443
# Option B: leave blank to use in-memory ChromaDB (simpler, data lost on restart)
# CHROMA_HOST = ""

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER = "openai"
EMBEDDING_MODEL = "text-embedding-3-small"

# ── App ───────────────────────────────────────────────────────────────────────
APP_LOG_LEVEL = "INFO"
MAX_SQL_ROWS = "2000"
RAG_TOP_K = "5"
